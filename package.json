{
  "name": "@carlwr/fastcheck-utils",
  "description": "improved generators for fast-check",
  "keywords": [
    "fast-check",
    "arbitraries",
    "generators"
  ],
  "author": {
    "name": "carlwr",
    "url": "https://github.com/carlwr"
  },
  "publisher": "carlwr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlwr/fastcheck-utils.git"
  },
  "bugs": {
    "url": "https://github.com/carlwr/fastcheck-utils/issues"
  },
  "homepage": "https://github.com/carlwr/fastcheck-utils#README.md",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.5.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsx build.ts",
    "prepack": "pnpm run qa >/dev/null && pnpm run build && pnpm run readme",
    "publish:dry": "pnpm pack --dry-run",
    "publish:release": "pnpm publish",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "format": "biome check --error-on-warnings --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "pnpm typecheck && pnpm lint && pnpm test",
    "readme": "tsx scripts/makeReadme.ts",
    "LAST_dummy": "false"
  },
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "fast-check": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@carlwr/typescript-extra": "^0.8.2",
    "@fast-check/vitest": "^0.4.0",
    "@types/node": "^25.6.0",
    "arg": "^5.0.2",
    "fast-check": "^4.7.0",
    "read-pkg": "^10.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6",
    "zzz_LAST_dummy": "npm:empty-npm-package@1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
